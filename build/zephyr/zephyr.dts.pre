  compatible = "st-morpho-header";
  #gpio-cells = <2>;
  gpio-map-mask = <0xFF 0x0>;
  gpio-map-pass-thru = <0x0 0x7F>;
  gpio-map = <0 0 &gpioc 10 0>,
      <1 0 &gpioc 11 0>,
