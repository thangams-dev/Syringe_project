# 1 "/home/thanga-inc-5829/Documents/Syringr_project/boards/nucleo_g474re.overlay" 1


/ {
 aliases {
  led0 = &led0_node;
  sw1 = &sw1_node;
  sw2 = &sw2_node;
  bu = &bu_node;
  st1 = &st1_node;
  dir1 = &dir1_node;
  enab1 = &enab1_node;
 };

 myoutputs {
  compatible = "gpio-leds";
  led0_node: led {
   gpios = <&gpiob 11 (0 << 0)>;
  };
  bu_node: buz {
   gpios = <&gpiob 12 (0 << 0)>;
  };
  st1_node: step {
   gpios = <&gpiob 13 (0 << 0)>;
  };
  dir1_node: direction {
   gpios = <&gpiob 14 (0 << 0)>;
  };
  enab1_node: enable {
   gpios = <&gpiob 15 (0 << 0)>;
  };
 };

 my_inputs {
  compatible = "gpio-keys";
  sw1_node: switch1 {
   gpios = <&gpioc 8 ((1 << 0) | (1 << 4))>;
  };
  sw2_node: switch2 {
   gpios = <&gpioc 9 ((1 << 0) | (1 << 4))>;
  };
 };
};

&usart1 {
 status = "okay";
 current-speed = <115200>;
};
